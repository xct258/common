substitutions:
  name: esp01s-1
  friendly_name: esp01s-1

esphome:
  name: ${name}
  friendly_name: ${friendly_name}
  min_version: 2024.6.0
  name_add_mac_suffix: false
  project:
    name: esphome.web
    version: dev

esp8266:
  board: esp01_1m

# Enable logging
logger:

# Enable Home Assistant API
api:

# Allow Over-The-Air updates
ota:
- platform: esphome

wifi:
  ssid: !secret wifi_ssid
  password: !secret wifi_password

web_server:
  port: 80


globals:
  # 定义全局变量，用于记录小风扇开启的总时间（秒）
  - id: fan_runtime_seconds
    type: int
    # 数据持久化（重启后不会清零）
    #restore_value: true
    initial_value: '0'
    

interval:
  # 定时任务，每秒记录小风扇的开启时间
  - interval: 1s
    then:
      - if:
          condition:
            switch.is_on: xiaofengshan
          then:
            - lambda: |-
                id(fan_runtime_seconds) += 1;

switch:
  # 使用GPIO2引脚，继电器需要低电平触发，已设置好上电不闪烁
  - platform: gpio
    pin:
      number: GPIO2
      inverted: true  # 适配低电平触发的继电器
    name: "$friendly_name"
    id: xiaofengshan
    restore_mode: ALWAYS_OFF  # 上电默认关闭
    on_turn_on:
      - lambda: |-
          ESP_LOGD("fan", "小风扇已打开");
    on_turn_off:
      - lambda: |-
          ESP_LOGD("fan", "小风扇已关闭");


  - platform: restart
    name: ${name} 重启

sensor:

  - platform: wifi_signal
    name: WiFi 信号
    update_interval: 600s

  - platform: uptime
    name: ${name} 运行时间（用于计算结果，不显示在界面）
    id: uptime_sensor_days
    update_interval: 60s
    internal: true  # 隐藏此传感器
    on_raw_value:
      then:
        - text_sensor.template.publish:
            id: uptime_human
            state: !lambda |-
              int seconds = round(id(uptime_sensor_days).raw_state);
              int days = seconds / (24 * 3600);
              seconds = seconds % (24 * 3600);
              int hours = seconds / 3600;
              seconds = seconds % 3600;
              int minutes = seconds /  60;
              return (
                (days ? String(days) + "天 " : "") +
                (hours ? String(hours) + "小时 " : "") +
                (minutes ? String(minutes) + "分钟 " : "")
              ).c_str();

time:
  - platform: homeassistant
    id: homeassistant_time

# Text sensors with general information.
text_sensor:
  - platform: version
    name: 版本
  - platform: wifi_info
    ip_address:
      name: IP 地址
    bssid:
      name: BSSID

  - platform: template
    name: $name 启动时间
    id: uptime_human
    icon: mdi:clock-outline
    update_interval: 60s

  - platform: template
    name: $friendly_name 启动时间
    id: fan_runtime_human
    icon: mdi:clock-outline
    lambda: |-
      int seconds = id(fan_runtime_seconds);
      int days = seconds / (24 * 3600);
      seconds = seconds % (24 * 3600);
      int hours = seconds / 3600;
      seconds = seconds % 3600;
      int minutes = seconds / 60;
      std::string result = "";
      if (days > 0) result += std::to_string(days) + "天 ";
      if (hours > 0) result += std::to_string(hours) + "小时 ";
      if (minutes > 0) result += std::to_string(minutes) + "分钟";
      return result;
    update_interval: 60s
