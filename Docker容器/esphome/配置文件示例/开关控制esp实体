substitutions:
  name: esphome-web-f217d0
  friendly_name: esp32-1

esphome:
  name: ${name}
  friendly_name: ${friendly_name}
  min_version: 2024.6.0
  name_add_mac_suffix: false
  project:
    name: esphome.web
    version: dev

esp32:
  board: esp32dev
  framework:
    type: arduino

# Enable logging
logger:

# Enable Home Assistant API
api:

# Allow Over-The-Air updates
ota:
- platform: esphome

# Allow provisioning Wi-Fi via serial
improv_serial:

wifi:
  # Set up a wifi access point
  ap: {}

# In combination with the `ap` this allows the user
# to provision wifi credentials to the device via WiFi AP.
captive_portal:

dashboard_import:
  package_import_url: github://esphome/example-configs/esphome-web/esp32.yaml@main
  import_full_config: true

# Sets up Bluetooth LE (Only on ESP32) to allow the user
# to provision wifi credentials to the device.
esp32_improv:
  authorizer: none

# To have a "next url" for improv serial
web_server:

globals:
  # 定义全局变量，用于记录小风扇开启的总时间（秒）
  - id: fan_runtime_seconds
    type: int
    # 数据持久化（重启后不会清零）
    #restore_value: true
    initial_value: '0'
    

interval:
  # 定时任务，每秒记录小风扇的开启时间
  - interval: 1s
    then:
      - if:
          condition:
            switch.is_on: xiaofengshan
          then:
            - lambda: |-
                id(fan_runtime_seconds) += 1;

switch:
  - platform: gpio
    pin: GPIO21
    name: "$friendly_name"
    inverted: true
    id: xiaofengshan
    on_turn_on:
      - lambda: |-
          ESP_LOGD("fan", "小风扇已打开");
    on_turn_off:
      - lambda: |-
          ESP_LOGD("fan", "小风扇已关闭");

  - platform: restart
    name: ${name} 重启


binary_sensor:
  - platform: gpio
    pin: GPIO19
    name: "输入传感器"
    id: input_sensor
    on_press:
      - switch.toggle: xiaofengshan  # 当传感器被激活时，切换小风扇的状态
    on_release:
      - switch.toggle: xiaofengshan  # 当传感器状态释放时，切换小风扇的状态

binary_sensor:
  - platform: gpio
    pin: GPIO19
    name: "输入传感器"
    id: input_sensor

sensor:

  - platform: wifi_signal
    name: WiFi 信号
    update_interval: 600s

  - platform: uptime
    name: ${name} 运行时间（用于计算结果，不显示在界面）
    id: uptime_sensor_days
    update_interval: 60s
    internal: true  # 隐藏此传感器
    on_raw_value:
      then:
        - text_sensor.template.publish:
            id: uptime_human
            state: !lambda |-
              int seconds = round(id(uptime_sensor_days).raw_state);
              int days = seconds / (24 * 3600);
              seconds = seconds % (24 * 3600);
              int hours = seconds / 3600;
              seconds = seconds % 3600;
              int minutes = seconds /  60;
              return (
                (days ? String(days) + "天 " : "") +
                (hours ? String(hours) + "小时 " : "") +
                (minutes ? String(minutes) + "分钟 " : "")
              ).c_str();

time:
  - platform: homeassistant
    id: homeassistant_time

# Text sensors with general information.
text_sensor:
  - platform: version
    name: 版本
  - platform: wifi_info
    ip_address:
      name: IP 地址
    bssid:
      name: BSSID

  - platform: template
    name: $name 启动时间
    id: uptime_human
    icon: mdi:clock-outline
    update_interval: 60s

  - platform: template
    name: $friendly_name 启动时间
    id: fan_runtime_human
    icon: mdi:clock-outline
    lambda: |-
      int seconds = id(fan_runtime_seconds);
      int days = seconds / (24 * 3600);
      seconds = seconds % (24 * 3600);
      int hours = seconds / 3600;
      seconds = seconds % 3600;
      int minutes = seconds / 60;
      std::string result = "";
      if (days > 0) result += std::to_string(days) + "天 ";
      if (hours > 0) result += std::to_string(hours) + "小时 ";
      if (minutes > 0) result += std::to_string(minutes) + "分钟";
      return result;
    update_interval: 60s
